    "@prisma/client": "^7.6.0",
    "@prisma/config": "^7.4.1",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jsrsasign": "^11.1.0",
    "nunjucks": "^3.2.4",
