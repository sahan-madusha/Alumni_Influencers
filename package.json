  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon -e ts,js,json --exec \"npx ts-node src/index.ts\"",
    "build": "tsc && npm run postbuild",
    "postbuild": "cp -r src/Templates dist/Templates 2>/dev/null || xcopy src\\Templates dist\\Templates /E /I /Y",
    "prisma:generate": "npx prisma generate",
    "prisma:deploy": "npx prisma migrate deploy",
    "test:db": "ts-node src/test-db.ts",
    "swagger": "ts-node src/swagger-gen.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
