    "@types/jsrsasign": "^10.5.15",
    "@types/node": "^25.0.9",
    "@types/nodemailer": "^7.0.11",
    "@types/nunjucks": "^3.2.6",
    "@types/pg": "^8.16.0",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.11",
    "prisma": "^7.6.0",
    "swagger-autogen": "^2.23.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
