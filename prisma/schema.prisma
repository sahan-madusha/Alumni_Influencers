generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// =========================
// USER
// =========================
// Status field mimics ENUM: "ACTIVE" | "INACTIVE" | "PENDING"
model User {
  id       String     @id @default(uuid())
  email    String     @unique
  password String
  name     String?
  status   String     @default("ACTIVE")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}
