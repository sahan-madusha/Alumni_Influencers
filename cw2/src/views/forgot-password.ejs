<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') %>
  <body class="bg-light">
    <div class="container">
      <div class="row justify-content-center align-items-center vh-100">
        <div class="col-md-5 col-lg-4">
          <div class="card border-0 shadow-lg p-4" style="border-radius: 20px">
            <div class="text-center mb-4">
              <div class="h2 fw-bold text-primary mb-1">Alumni Influencers</div>
              <p class="text-muted small">Forgot Password</p>
            </div>

            <p class="text-muted small text-center mb-4">
              Enter your email address and we'll send you a link to reset your password.
            </p>

            <form id="forgotPasswordForm">
              <div class="mb-4">
                <label class="form-label small fw-bold">Email Address</label>
                <input
                  type="email"
                  id="email"
                  class="form-control p-3"
                  placeholder="name@iit.ac.lk"
                  required
                />
              </div>

              <div
                id="message"
                class="alert d-none small"
              ></div>

              <button
                type="submit"
                id="submitBtn"
                class="btn btn-primary w-100 p-3 fw-bold"
                style="border-radius: 12px"
              >
                Send Reset Link
              </button>
            </form>

            <div class="text-center mt-4">
              <p class="text-muted small mb-0">
                Remember your password?
                <a href="/" class="text-primary fw-bold text-decoration-none"
                  >Sign In</a
                >
              </p>
            </div>
          </div>
          <p class="text-center text-muted small mt-4">
            © 2026 IIT Alumni Network
          </p>
        </div>
      </div>
    </div>

    <script>
      document.getElementById("forgotPasswordForm").addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = document.getElementById("email").value;
        const msgDiv = document.getElementById("message");
        const btn = document.getElementById("submitBtn");

        msgDiv.classList.add("d-none");
        msgDiv.classList.remove("alert-danger", "alert-success");
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Sending...';

        try {
          const response = await fetch("/api/v1/user/password-reset-request", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ email }),
          });

          const data = await response.json();

          if (response.ok) {
            msgDiv.textContent = "Reset link sent! Please check your email.";
            msgDiv.classList.add("alert-success");
            msgDiv.classList.remove("d-none");
            document.getElementById("forgotPasswordForm").reset();
          } else {
            let errorMsg = data.message || "Failed to send reset link.";
            if (data.errors && data.errors.length > 0) {
              errorMsg = data.errors[0].message;
            }
            msgDiv.textContent = errorMsg;
            msgDiv.classList.add("alert-danger");
            msgDiv.classList.remove("d-none");
          }
        } catch (err) {
          msgDiv.textContent = "A server error occurred. Please try again later.";
          msgDiv.classList.add("alert-danger");
          msgDiv.classList.remove("d-none");
        } finally {
          btn.disabled = false;
          btn.textContent = "Send Reset Link";
        }
      });
    </script>
    <%- include('partials/footer') %>
  </body>
</html>
