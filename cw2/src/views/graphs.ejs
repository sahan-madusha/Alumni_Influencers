<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') %>
  <body>
    <%- include('partials/header') %>

    <main class="container py-5 mt-5">
      <div class="mb-4">
        <h1 class="fw-bold mb-1">Advanced Analytics</h1>
        <p class="text-muted">Deep dive into alumni professional development trends</p>
      </div>

      <div class="row g-4">
        <!-- Reusing charts from dashboard but in a focused view -->
        <% const charts = [
            { id: 'skillsGapChart', title: 'Certifications vs Curriculum', icon: 'bi-mortarboard' },
            { id: 'cloudGrowthChart', title: 'Cloud Technology Adoption', icon: 'bi-cloud' },
            { id: 'agileScrumChart', title: 'Agile Methodology Trends', icon: 'bi-arrow-repeat' },
            { id: 'pathwayChart', title: 'Career Progression Pathways', icon: 'bi-compass' }
        ]; %>
        
        <% charts.forEach(chart => { %>
          <div class="col-md-6">
            <div class="card p-4 shadow-sm border-0 h-100" style="border-radius: 16px;">
              <h6 class="fw-bold mb-3"><i class="bi <%= chart.icon %> me-2 text-primary"></i><%= chart.title %></h6>
              <canvas id="<%= chart.id %>"></canvas>
            </div>
          </div>
        <% }) %>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
      const analytics = <%- JSON.stringify(analytics) %>;
      const colors = ['#6366f1', '#22d3ee', '#f59e0b', '#10b981', '#ef4444', '#8b5cf6', '#ec4899', '#3b82f6'];

      // Skills Gap
      new Chart(document.getElementById('skillsGapChart'), {
          type: 'bar',
          data: {
              labels: Object.keys(analytics.skillsGap),
              datasets: [{ data: Object.values(analytics.skillsGap), backgroundColor: colors[0] }]
          },
          options: { plugins: { legend: { display: false } } }
      });

      // Cloud Growth
      new Chart(document.getElementById('cloudGrowthChart'), {
          type: 'line',
          data: {
              labels: Object.keys(analytics.cloudGrowth),
              datasets: [{ label: 'Growth', data: Object.values(analytics.cloudGrowth), borderColor: colors[1], tension: 0.4 }]
          }
      });

      // Agile/Scrum
      new Chart(document.getElementById('agileScrumChart'), {
          type: 'doughnut',
          data: {
              labels: Object.keys(analytics.agileScrum),
              datasets: [{ data: Object.values(analytics.agileScrum), backgroundColor: [colors[4], '#e5e7eb'] }]
          }
      });

      // Pathways
      new Chart(document.getElementById('pathwayChart'), {
          type: 'radar',
          data: {
              labels: Object.keys(analytics.careerPathways),
              datasets: [{ label: 'Density', data: Object.values(analytics.careerPathways), backgroundColor: 'rgba(139, 92, 246, 0.2)', borderColor: '#8b5cf6' }]
          }
      });
    </script>

    <%- include('partials/footer') %>
  </body>
</html>
