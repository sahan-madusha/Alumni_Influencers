<!DOCTYPE html>
<html lang="en">
  <%- include('partials/head') %>
  <body class="bg-light">
    <div class="container">
      <div class="row justify-content-center align-items-center vh-100">
        <div class="col-md-5 col-lg-4">
          <div class="card border-0 shadow-lg p-4" style="border-radius: 20px">
            <div class="text-center mb-4">
              <div class="h2 fw-bold text-primary mb-1">Alumni Influencers</div>
              <p class="text-muted small">Set New Password</p>
            </div>

            <form id="resetPasswordForm">
              <div class="mb-3">
                <label class="form-label small fw-bold">New Password</label>
                <input
                  type="password"
                  id="password"
                  class="form-control p-3"
                  placeholder="**********"
                  required
                />
              </div>

              <div class="mb-4">
                <label class="form-label small fw-bold">Confirm Password</label>
                <input
                  type="password"
                  id="confirmPassword"
                  class="form-control p-3"
                  placeholder="**********"
                  required
                />
              </div>

              <div
                id="message"
                class="alert d-none small"
              ></div>

              <button
                type="submit"
                id="submitBtn"
                class="btn btn-primary w-100 p-3 fw-bold"
                style="border-radius: 12px"
              >
                Reset Password
              </button>
            </form>

            <div class="text-center mt-4">
              <p class="text-muted small mb-0">
                Back to
                <a href="/" class="text-primary fw-bold text-decoration-none"
                  >Sign In</a
                >
              </p>
            </div>
          </div>
          <p class="text-center text-muted small mt-4">
            © 2026 IIT Alumni Network
          </p>
        </div>
      </div>
    </div>

    <script>
      const urlParams = new URLSearchParams(window.location.search);
      const id = urlParams.get('id');
      const token = urlParams.get('token');

      document.getElementById("resetPasswordForm").addEventListener("submit", async (e) => {
        e.preventDefault();
        const password = document.getElementById("password").value;
        const confirmPassword = document.getElementById("confirmPassword").value;
        const msgDiv = document.getElementById("message");
        const btn = document.getElementById("submitBtn");

        if (password !== confirmPassword) {
          msgDiv.textContent = "Passwords do not match.";
          msgDiv.classList.add("alert-danger");
          msgDiv.classList.remove("d-none");
          return;
        }

        if (!id || !token) {
          msgDiv.textContent = "Invalid or missing reset link parameters.";
          msgDiv.classList.add("alert-danger");
          msgDiv.classList.remove("d-none");
          return;
        }

        msgDiv.classList.add("d-none");
        msgDiv.classList.remove("alert-danger", "alert-success");
        btn.disabled = true;

        try {
          const response = await fetch("/api/v1/user/password-reset", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ id, token, password }),
          });

          const data = await response.json();

          if (response.ok) {
            msgDiv.textContent = "Password reset successful! Redirecting to login...";
            msgDiv.classList.add("alert-success");
            msgDiv.classList.remove("d-none");
            setTimeout(() => {
              window.location.href = "/";
            }, 2000);
          } else {
            let errorMsg = data.message || "Failed to reset password.";
            if (data.errors && data.errors.length > 0) {
              errorMsg = data.errors[0].message;
            }
            msgDiv.textContent = errorMsg;
            msgDiv.classList.add("alert-danger");
            msgDiv.classList.remove("d-none");
          }
        } catch (err) {
          msgDiv.textContent = "A server error occurred. Please try again later.";
          msgDiv.classList.add("alert-danger");
          msgDiv.classList.remove("d-none");
        } finally {
          btn.disabled = false;
          btn.textContent = "Reset Password";
        }
      });
    </script>
    <%- include('partials/footer') %>
  </body>
</html>
